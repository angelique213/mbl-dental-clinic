<%- include("../partials/header", {
    title: "Edit Service",
    subtitle: "Update Dental Service",
    css: "appointments"
}) %>

<div class="form-container">

    <h2>Edit Service</h2>

    <form
        action="/admin/services/edit/<%= service.service_id %>"
        method="POST"
    >

        <div class="form-group">

            <label for="service_name">
                Service Name
            </label>

            <input
                type="text"
                id="service_name"
                name="service_name"
                value="<%= service.service_name %>"
                required
            >

        </div>

        <div class="form-group">

            <label for="description">
                Description
            </label>

            <textarea
                id="description"
                name="description"
                rows="4"
            ><%= service.description %></textarea>

        </div>

        <div class="form-group">

            <label for="price">
                Price (₱)
            </label>

            <input
                type="number"
                id="price"
                name="price"
                min="0"
                step="0.01"
                value="<%= service.price %>"
                required
            >

        </div>

        <button
            type="submit"
            class="add-button"
        >
            Update Service
        </button>

        <a
            href="/admin/services"
            class="transactions-btn"
        >
            Cancel
        </a>

    </form>

</div>

<%- include("../partials/footer") %>