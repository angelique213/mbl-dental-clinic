<%- include("../partials/header", {
    title: "Add Service",
    subtitle: "Create a New Dental Service",
    css: "appointments"
}) %>

<div class="form-container">

    <h2>Add New Service</h2>

    <form
        action="/admin/services/add"
        method="POST"
    >

        <div class="form-group">

            <label for="service_name">
                Service Name
            </label>

            <input
                type="text"
                id="service_name"
                name="service_name"
                placeholder="Enter service name"
                required
            >

        </div>

        <div class="form-group">

            <label for="description">
                Description
            </label>

            <textarea
                id="description"
                name="description"
                rows="4"
                placeholder="Enter service description"
            ></textarea>

        </div>

        <div class="form-group">

            <label for="price">
                Price (₱)
            </label>

            <input
                type="number"
                id="price"
                name="price"
                min="0"
                step="0.01"
                placeholder="Enter price"
                required
            >

        </div>

        <button
            type="submit"
            class="add-button"
        >
            Save Service
        </button>

        <a
            href="/admin/services"
            class="transactions-btn"
        >
            Cancel
        </a>

    </form>

</div>

<%- include("../partials/footer") %>