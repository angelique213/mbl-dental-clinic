<!DOCTYPE html>
<html lang="en">
<head>
  <!-- basic page information -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>MBL Dental Clinic</title>

  <!-- connect css file -->
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <!-- clinic header -->
  <header class="header">

    <!-- clinic logo -->
    <img
      src="/images/logo.png"
      alt="MBL Dental Clinic Logo"
      class="header-logo"
    >

    <!-- clinic title and navigation -->
    <div class="header-content">
      <h1>MBL Dental Clinic</h1>

      <p class="subtitle">
        Booking and Management System
      </p>

      <!-- navigation menu -->
      <nav>
        <a href="/">Dashboard</a>
        <a href="/patients">Patients</a>
        <a href="/appointments">Appointments</a>
      </nav>
    </div>

  </header>

  <main>
    <!-- dashboard summary cards -->
    <section class="dashboard">

      <div class="card">
        <h2>Patients</h2>
        <p>0</p>
      </div>

      <div class="card">
        <h2>Appointments</h2>
        <p>0</p>
      </div>

      <div class="card">
        <h2>Services</h2>
        <p>4</p>
      </div>

    </section>

    <!-- welcome section -->
    <section class="welcome-section">

      <div class="welcome-card">
        <h2>Welcome to MBL Dental Clinic</h2>

        <p class="welcome-text">
          This system helps manage patient records,
          appointments, and dental services.
          Use the navigation menu above to get started.
        </p>
      </div>

    </section>
  </main>
</body>
</html>