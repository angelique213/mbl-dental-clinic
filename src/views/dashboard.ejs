<%- include("partials/header", {
    title: "MBL Dental Clinic",
    subtitle: "Booking and Management System",
    css: "dashboard"
}) %>

<% if (!user) { %>

<section class="dashboard">

    <div class="card">
        <h2>Our Services</h2>
        <p><%= typeof serviceCount !== "undefined" ? serviceCount : 5 %></p>
        <small>Dental Services Available</small>
    </div>

    <div class="card">
        <h2>Business Hours</h2>
        <p>Mon - Sat</p>
        <small>9:00 AM - 5:00 PM</small>
    </div>

    <div class="card">
        <h2>Book Online</h2>
        <p>Fast & Easy</p>
        <small>Register to schedule your visit</small>
    </div>

</section>

<section class="welcome-section">

    <div class="welcome-card">

        <h2>Welcome to MBL Dental Clinic</h2>

        <p class="welcome-text">
            We provide quality dental care for individuals and families.
            Create an account or log in to book appointments online, manage your dental records, and explore our available services.
        </p>

        <div style="margin-top:25px;">

            <a
                class="add-button"
                href="/login"
            >
                Login
            </a>

            <a
                class="add-button"
                href="/register"
                style="margin-left:12px;"
            >
                Register
            </a>

        </div>

    </div>

</section>

<section class="welcome-section">

    <div class="welcome-card">

        <h2>Why Choose MBL Dental Clinic?</h2>

        <ul class="features">

            <li>✔ Experienced Dentists</li>
            <li>✔ Modern Dental Equipment</li>
            <li>✔ Online Appointment Booking</li>
            <li>✔ Friendly and Professional Care</li>
            <li>✔ Family-Friendly Dental Services</li>

        </ul>

    </div>

</section>

<% } else if (user.role === "admin") { %>

<section class="dashboard">

    <div class="card">

        <h2>Patients</h2>

        <p><%= patientCount %></p>

    </div>

    <div class="card">

        <h2>Appointments</h2>

        <p><%= appointmentCount %></p>

    </div>

    <div class="card">

        <h2>Services</h2>

        <p><%= serviceCount %></p>

    </div>

</section>

<section class="welcome-section">

    <div class="welcome-card">

        <h2>Administrator Dashboard</h2>

        <p class="welcome-text">
            Manage patients, appointments, services, and clinic records from one convenient dashboard.
        </p>

        <a
            class="add-button"
            href="/admin"
        >
            Open Admin Panel
        </a>

    </div>

</section>

<% } else { %>

<section class="dashboard">

    <div class="card">

        <h2>My Appointments</h2>

        <p><%= appointmentCount %></p>

        <a
            href="/appointments"
            class="add-button"
            style="margin-top:15px;display:inline-block;"
        >
            View
        </a>

    </div>

    <div class="card">

        <h2>Services</h2>

        <p><%= serviceCount %></p>

    </div>

    <div class="card">

        <h2>Status</h2>

        <p><%= latestStatus %></p>

    </div>

</section>

<section class="welcome-section">

    <div class="welcome-card">

        <h2>Patient Dashboard</h2>

        <p class="welcome-text">
            Welcome back! Book a new appointment, view your upcoming visits, and manage your dental care online.
        </p>

        <div style="margin-top:25px;">

            <a
                class="add-button"
                href="/appointments/add"
            >
                Book Appointment
            </a>

            <a
                class="add-button"
                href="/appointments"
                style="margin-left:12px;"
            >
                My Appointments
            </a>

        </div>

    </div>

</section>

<% } %>

<%- include("partials/footer") %>